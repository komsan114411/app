# ─── REQUIRED ────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# MongoDB — use Atlas in production; use mongodb://mongo:27017/baansuan with docker-compose
MONGO_URI=mongodb://127.0.0.1:27017/baansuan

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_HEX_CHARS_OR_LONGER
REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_HEX_CHARS

# Argon2id parameters — higher = more secure + slower. OWASP 2024 minimums satisfied.
# ARGON2_MEMORY in KiB. 65536 = 64 MiB. Lower only if RAM-constrained.
ARGON2_MEMORY=65536
ARGON2_TIME=3
ARGON2_PARALLEL=1

# Where to accept CORS from. Comma-separated. Exact origins only (no wildcards).
CORS_ORIGINS=https://your-app.example.com

# Cookie settings
COOKIE_DOMAIN=.your-domain.example.com
COOKIE_SECURE=true

# Salt for IP hashing in analytics (so we don't store raw IPs)
IP_SALT=CHANGE_ME_RANDOM_STRING

# Trust proxy header depth (behind nginx/cloudflare). 1 = one hop.
TRUST_PROXY=1

# ─── BOOTSTRAP FIRST ADMIN (used by seed.js only) ─────────────
# If unset, the defaults are loginId=admin123 / password=admin123.
# System forces password change on first login regardless of these values.
# ADMIN_LOGIN_ID=admin123
# ADMIN_PASSWORD=admin123
