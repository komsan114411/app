# ─── REQUIRED ────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# MongoDB — use Atlas in production; docker-compose sets this automatically.
MONGO_URI=mongodb://127.0.0.1:27017/myapp

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_HEX_CHARS_OR_LONGER
# Optional: previous secret accepted during grace window while rotating
# JWT_SECRET_PREV=
REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_HEX_CHARS

# argon2id parameters — higher = more secure + slower.
ARGON2_MEMORY=65536
ARGON2_TIME=3
ARGON2_PARALLEL=1

# CORS allow-list (comma-separated exact origins). Same-origin is auto-allowed.
CORS_ORIGINS=https://your-app.example.com

# Cookies
COOKIE_DOMAIN=.your-domain.example.com
COOKIE_SECURE=true

# IP hashing salt (HMAC-SHA256 over req.ip for analytics dedup — no raw IPs stored)
IP_SALT=CHANGE_ME_RANDOM_STRING

# Trust proxy hops — 1 = single reverse proxy (nginx, Railway, Render default).
TRUST_PROXY=1

# ─── FIRST-ADMIN BOOTSTRAP ───────────────────────────────────
# If unset, the server auto-generates a strong random password on first
# boot and prints it ONCE to stdout. Read it from your deploy logs
# (Railway/Render/Fly), log in at /admin, then change it. Subsequent
# boots do nothing because the admin account already exists.
# Override only when you need reproducible credentials (e.g. staging):
# ADMIN_LOGIN_ID=admin
# ADMIN_PASSWORD=<strong-random-string>
# Break-glass password reset (ADMIN_PASSWORD bypasses zxcvbn/HIBP):
# ADMIN_FORCE_RESET=true

# ─── OPTIONAL: EMAIL (for password reset) ────────────────────
# If unset, reset links are logged to stdout (dev mode — no mail sent).
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASSWORD=re_xxxxx
# SMTP_FROM=no-reply@your-domain.example.com
# APP_PUBLIC_URL=https://your-domain.example.com

# ─── OPTIONAL: REDIS (shared rate-limit store) ───────────────
# REDIS_URL=redis://default:pass@host:6379

# ─── OPTIONAL: CLOUDFLARE TURNSTILE (CAPTCHA) ────────────────
# TURNSTILE_SECRET=

# ─── OPTIONAL: WEB PUSH (VAPID) ──────────────────────────────
# npx web-push generate-vapid-keys
# PUSH_VAPID_PUBLIC=
# PUSH_VAPID_PRIVATE=
# PUSH_VAPID_SUBJECT=mailto:admin@your-domain.example.com

# ─── OPTIONAL: UPLOADS ───────────────────────────────────────
# UPLOAD_DIR=uploads
# UPLOAD_MAX_BYTES=2097152

# ─── OPTIONAL: LOGGING SINK ──────────────────────────────────
# LOG_TRANSPORT=stdout
# LOKI_URL=
